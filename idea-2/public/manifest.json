{
  "manifest_version": 3,
  "name": "Venice AI Reply Composer",
  "version": "1.0.7",
  "description": "AI-powered reply suggestions with Bankr integration",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.farcaster.xyz/*",
    "https://farcaster.xyz/*",
    "https://*.warpcast.com/*",
    "https://warpcast.com/*",
    "https://*.farcaster.com/*",
    "https://farcaster.com/*",
    "https://*.twitter.com/*",
    "https://twitter.com/*",
    "https://*.x.com/*",
    "https://x.com/*",
    "https://*.reddit.com/*",
    "https://reddit.com/*",
    "https://api.venice.ai/*",
    "https://llm.bankr.bot/*",
    "https://api.bankr.bot/*",
    "https://bankr.bot/*",
    "https://models.inference.ai.azure.com/*",
    "https://api.coingecko.com/*",
    "https://hub-api.neynar.com/*",
    "https://api.neynar.com/*",
    "https://fnames.farcaster.xyz/*",
    "https://mainnet.base.org/*",
    "https://mainnet.optimism.io/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.farcaster.xyz/*",
        "https://farcaster.xyz/*",
        "https://*.warpcast.com/*",
        "https://warpcast.com/*",
        "https://*.farcaster.com/*",
        "https://farcaster.com/*",
        "https://*.twitter.com/*",
        "https://twitter.com/*",
        "https://*.x.com/*",
        "https://x.com/*",
        "https://*.reddit.com/*",
        "https://reddit.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
